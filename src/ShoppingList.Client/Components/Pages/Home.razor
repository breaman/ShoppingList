@page "/"
@rendermode InteractiveWebAssembly

<h3>Shopping Lists</h3>
<a href="/shopping-list/new" class="btn btn-primary mb-3">Create New List</a>
<div class="row g-4">
    @foreach (var list in _shoppingLists ?? [])
    {
        <div class="col-md-4" @key="list.ShoppingListId">
            @if (_editingListId == list.ShoppingListId)
            {
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="form-floating mb-2">
                            <InputText id="@($"edit-name-{list.ShoppingListId}")" class="form-control" @bind-Value="_editingName" placeholder="" />
                            <label for="@($"edit-name-{list.ShoppingListId}")">Name</label>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary btn-sm" @onclick="SaveEditAsync">Save</button>
                            <button class="btn btn-secondary btn-sm" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start">
                            <a href="/shopping-list/@list.ShoppingListId" class="text-decoration-none text-dark flex-grow-1">
                                <h5 class="card-title">@list.Name</h5>
                                <p class="card-text text-muted">@list.RemainingItems/@list.TotalItems items remaining</p>
                            </a>
                            <div class="d-flex gap-2 ms-2">
                                <span role="button" @onclick="@(_ => BeginEdit(list))">
                                    <i class="bi bi-pencil-fill lead"></i>
                                </span>
                                <span class="text-danger" role="button" @onclick="@(_ => ConfirmDelete(list))">
                                    <i class="bi bi-trash3-fill text-danger lead"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_listPendingDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Shopping List</h5>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>@_listPendingDelete.Name</strong>? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="ExecuteDeleteAsync">Delete</button>
                </div>
            </div>
        </div>
    </div>
}
