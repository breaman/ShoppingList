@page "/"
<h3>Shopping Lists</h3>
<a href="/shopping-list/new" class="btn btn-primary mb-3">Create New List</a>
<div class="row g-4">
    @foreach (var list in _shoppingLists ?? [])
    {
        <div class="col-md-4">
            <a href="/shopping-list/@list.ShoppingListId" class="card h-100 text-decoration-none text-dark">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-header">@list.Name</h5>
                    <p class="card-text text-muted">@list.CreatedOn</p>
                </div>
            </a>
        </div>
    }
</div>