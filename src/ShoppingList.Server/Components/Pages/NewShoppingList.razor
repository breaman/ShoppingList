@page "/shopping-list/new"

<h3>New Shopping List</h3>

<EditForm Model="ShoppingList" OnValidSubmit="HandleValidSubmit" method="post" FormName="new-shopping-list">
    <DataAnnotationsValidator />
    <ValidationSummary />
    
    <div class="form-floating mb-3">
        <InputText id="shopping-list-name" class="form-control" @bind-Value="ShoppingList.Name" placeholder="" />
        <label class="form-label" for="shopping-list-name">Name <span class="text-danger">*</span></label>
    </div>
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/" class="btn btn-secondary">Cancel</a>
    </div>
</EditForm>